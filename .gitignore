# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local

# typescript
*.tsbuildinfo

app-example

# generated native folders
/ios
/android

# harness diagnostics — per-session screenshots, logs, junit reports
tmp/diagnostics/

# Maestro run artifacts that live outside the repo (~/.maestro/) — not
# ignored here, just noted: scripts/run-maestro.sh copies the relevant
# artifacts into tmp/diagnostics/ for in-repo discoverability.
