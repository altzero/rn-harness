{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "feature_list",
  "type": "object",
  "required": ["project", "features"],
  "properties": {
    "project": { "type": "string" },
    "description": { "type": "string" },
    "states": {
      "type": "array",
      "items": { "type": "string", "enum": ["todo", "in_progress", "blocked", "done"] }
    },
    "wipLimit": { "type": "integer", "minimum": 1 },
    "features": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "description", "verification", "status", "passes"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "title": { "type": "string" },
          "category": { "type": "string" },
          "description": { "type": "string" },
          "verification": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
          "status": { "enum": ["todo", "in_progress", "blocked", "done"] },
          "passes": { "type": "boolean" },
          "owner": { "type": ["string", "null"] },
          "commitSha": { "type": ["string", "null"] },
          "notes": { "type": "string" }
        }
      }
    }
  }
}
